<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Telefon durumunu okuma -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- Aramayı cevaplama (API 26+) -->
    <uses-permission android:name="android.permission.ANSWER_PHONE_CALLS" />

    <!-- Foreground Service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <!-- Bildirim gönderme (API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Rehber erişimi (arayan ismini göstermek için) -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- Arama loglarını okuma -->
    <uses-permission android:name="android.permission.READ_CALL_LOG" />

    <!-- Ses kaydı (ileride gerekebilir) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Telecom yönetimi -->
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />

    <!-- Ağ erişimi (Chatterbox model indirme) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".ImBusyApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SuAnMesgulum"
        tools:targetApi="34">

        <!-- Ana Activity -->
        <activity
            android:name=".presentation.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.SuAnMesgulum">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Gelen Arama Tam Ekran Activity -->
        <activity
            android:name=".presentation.incomingcall.IncomingCallActivity"
            android:exported="false"
            android:theme="@style/Theme.SuAnMesgulum.IncomingCall"
            android:excludeFromRecents="true"
            android:taskAffinity="com.suanmesgulum.incomingcall"
            android:launchMode="singleInstance"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:showOnLockScreen="true" />

        <!-- Mod Seçim Activity (Bildirimden açılır) -->
        <activity
            android:name=".presentation.modeselect.ModeSelectActivity"
            android:exported="false"
            android:theme="@style/Theme.SuAnMesgulum.Dialog"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:launchMode="singleInstance" />

        <!-- v2: Canlı Arama Ekranı -->
        <activity
            android:name=".presentation.livecall.LiveCallActivity"
            android:exported="false"
            android:theme="@style/Theme.SuAnMesgulum.IncomingCall"
            android:excludeFromRecents="true"
            android:taskAffinity="com.suanmesgulum.livecall"
            android:launchMode="singleInstance"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:showOnLockScreen="true" />

        <!-- v2: Asistan Özelleştirme Ekranı -->
        <activity
            android:name=".presentation.assistant.AssistantCustomizeActivity"
            android:exported="false"
            android:theme="@style/Theme.SuAnMesgulum" />

        <!-- v2: Sesli Mesajlar Ekranı -->
        <activity
            android:name=".presentation.voicemail.VoicemailActivity"
            android:exported="false"
            android:theme="@style/Theme.SuAnMesgulum" />

        <!-- CallScreeningService: Gelen aramaları yakalama -->
        <service
            android:name=".service.BusyCallScreeningService"
            android:permission="android.permission.BIND_SCREENING_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.telecom.CallScreeningService" />
            </intent-filter>
            <meta-data
                android:name="android.telecom.INCLUDE_EXTERNAL_CALLS"
                android:value="false" />
        </service>

        <!-- Foreground Service: Arka planda çalışma -->
        <service
            android:name=".service.BusyForegroundService"
            android:exported="false"
            android:foregroundServiceType="phoneCall" />

        <!-- TTS Ses Oynatma Servisi -->
        <service
            android:name=".service.TtsPlaybackService"
            android:exported="false"
            android:foregroundServiceType="phoneCall" />

        <!-- v2: CallOrchestrator Servisi (Asistan çağrı yönetimi) -->
        <service
            android:name=".service.orchestrator.CallOrchestratorService"
            android:exported="false"
            android:foregroundServiceType="phoneCall|microphone" />

        <!-- BroadcastReceiver: Bildirim butonları ve çağrı aksiyonları -->
        <receiver
            android:name=".service.CallActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.suanmesgulum.ACTION_USE_MODE" />
                <action android:name="com.suanmesgulum.ACTION_SILENT_REJECT" />
                <action android:name="com.suanmesgulum.ACTION_STOP_SERVICE" />
                <action android:name="com.suanmesgulum.ACTION_ASSISTANT_ANSWER" />
                <action android:name="com.suanmesgulum.ACTION_IGNORE_CALL" />
            </intent-filter>
        </receiver>

        <!-- BroadcastReceiver: Telefon durumu değişikliği (CallScreeningService yedek mekanizması) -->
        <receiver
            android:name=".service.PhoneStateReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.PHONE_STATE" />
            </intent-filter>
        </receiver>

    </application>

</manifest>

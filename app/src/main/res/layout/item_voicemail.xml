<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Voicemail icon / unread badge -->
        <ImageView
            android:id="@+id/ivVoicemailIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_voicemail"
            app:tint="@color/primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvVoicemailCaller"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvVoicemailDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/tvVoicemailDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#888888" />

        </LinearLayout>

        <!-- Unread badge -->
        <TextView
            android:id="@+id/tvUnreadBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/voicemail_new"
            android:textSize="10sp"
            android:textColor="@android:color/white"
            android:background="@color/accent"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:visibility="gone" />

        <!-- Play button -->
        <ImageView
            android:id="@+id/ivPlayVoicemail"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_play"
            app:tint="@color/primary"
            android:contentDescription="@string/voicemail_play" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

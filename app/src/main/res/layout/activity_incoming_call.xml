<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8000000">

    <!-- Üst Bölüm: Arayan Bilgisi -->
    <LinearLayout
        android:id="@+id/layoutCallerInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="64dp"
        android:paddingHorizontal="24dp">

        <!-- Uygulama Etiket -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="14sp"
            android:textColor="#B0FFFFFF"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="24dp" />

        <!-- Arayan Simgesi -->
        <ImageView
            android:id="@+id/ivCallerIcon"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/ic_caller_avatar"
            android:contentDescription="Caller"
            app:tint="#FFFFFFFF" />

        <!-- Arayan Numara -->
        <TextView
            android:id="@+id/tvCallerNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bilinmeyen"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF"
            android:layout_marginTop="16dp" />

        <!-- Arayan İsim (rehberden) -->
        <TextView
            android:id="@+id/tvCallerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="16sp"
            android:textColor="#B0FFFFFF"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

        <!-- Durum Mesajı -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/incoming_call_label"
            android:textSize="14sp"
            android:textColor="#80FFFFFF"
            android:layout_marginTop="8dp" />

    </LinearLayout>

    <!-- Orta Bölüm: Mod Seçimi -->
    <LinearLayout
        android:id="@+id/layoutModeSelection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/layoutCallerInfo"
        android:layout_above="@id/layoutActions"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_busy_mode"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF"
            android:layout_marginBottom="16dp" />

        <!-- Mod Butonları Container -->
        <LinearLayout
            android:id="@+id/layoutModeButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center" />

        <!-- "Tüm Modları Göster" butonu -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShowAllModes"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/show_all_modes"
            android:textSize="13sp"
            android:textColor="#B0FFFFFF"
            app:cornerRadius="20dp"
            app:rippleColor="#30FFFFFF"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_marginTop="8dp" />

    </LinearLayout>

    <!-- Alt Bölüm: Reddet / Sessiz Reddet -->
    <LinearLayout
        android:id="@+id/layoutActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="48dp"
        android:paddingHorizontal="32dp">

        <!-- Sessizce Reddet Butonu -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSilentReject"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/silent_reject"
            android:textSize="16sp"
            android:textColor="#FFFFFFFF"
            app:backgroundTint="#FFE53935"
            app:icon="@drawable/ic_call_end"
            app:iconTint="#FFFFFFFF"
            app:iconGravity="textStart"
            app:cornerRadius="28dp"
            android:layout_marginBottom="12dp" />

        <!-- Aramayı Geçir (Müdahale etme) Butonu -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnIgnore"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="@string/ignore_call"
            android:textSize="14sp"
            android:textColor="#80FFFFFF"
            app:cornerRadius="22dp"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

    </LinearLayout>

</RelativeLayout>
